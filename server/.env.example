DB_PATH=data/chessorganizers.db
FIDE_API_KEY=
FIDE_SUBMIT_URL=
FIDE_RATING_SERVER=https://ratings.fide.com/
CORS_ORIGIN=*

# Email (SMTP — compatible with SendGrid, Gmail, etc.)
