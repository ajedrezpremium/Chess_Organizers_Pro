{
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/auth/(.*)", "destination": "/api/index.js" },
    { "source": "/public/(.*)", "destination": "/api/index.js" },
    { "source": "/tournaments/(.*)", "destination": "/api/index.js" },
    { "source": "/players/(.*)", "destination": "/api/index.js" },
    { "source": "/fide/(.*)", "destination": "/api/index.js" },
    { "source": "/stats/(.*)", "destination": "/api/index.js" },
    { "source": "/health", "destination": "/api/index.js" },
    { "source": "/health/readiness", "destination": "/api/index.js" },
    { "source": "/membership/(.*)", "destination": "/api/index.js" },
    { "source": "/validation/(.*)", "destination": "/api/index.js" },
    { "source": "/stripe/(.*)", "destination": "/api/index.js" },
    { "source": "/external/(.*)", "destination": "/api/index.js" },
    { "source": "/import/(.*)", "destination": "/api/index.js" },
    { "source": "/notifications/(.*)", "destination": "/api/index.js" },
    { "source": "/leagues/(.*)", "destination": "/api/index.js" },
    { "source": "/matches/(.*)", "destination": "/api/index.js" },
    { "source": "/teams/(.*)", "destination": "/api/index.js" },
    { "source": "/arbiters/(.*)", "destination": "/api/index.js" },
    { "source": "/api/v1/(.*)", "destination": "/api/index.js" },
    { "source": "/api-keys/(.*)", "destination": "/api/index.js" },
    { "source": "/ai/(.*)", "destination": "/api/index.js" },
    { "source": "/scan/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/api/index.js" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
