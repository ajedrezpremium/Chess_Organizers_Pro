# ── Producción: Chess Organizers Pro ──
# Copia este archivo como .env y completa los valores

# Obligatorio
DOMAIN=chessorganizerspro.com
PUBLIC_URL=https://chessorganizerspro.com
JWT_SECRET=genera_con_openssl_rand_-base64_48
CORS_ORIGIN=https://chessorganizerspro.com

# Base de datos
DB_PATH=/data/chessorganizers.db

# Correo (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxx

# Stripe (pagos)
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_BASIC=price_basic_monthly
STRIPE_PRICE_PRO=price_pro_monthly

# Twilio (WhatsApp/SMS)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_FROM_NUMBER=+14155238886

# FIDE
FIDE_API_KEY=xxxxx
FIDE_SUBMIT_URL=https://fide.com/submit

# Dockefile build (no cambiar)
NODE_ENV=production
PORT=4000
CLIENT_DIST=/app/client/dist
